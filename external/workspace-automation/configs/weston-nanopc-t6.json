{
  "id": "weston-nanopc-t6",
  "load": false,
  "supported_archs": [
    "aarch64",
    "arm64",
    "x86_64"
  ],
  "supported_host_types": [
    "darwin",
    "fedora",
    "ubuntu"
  ],
  "type": "remote",
  "env": {
    "DEVICE_HOSTNAME": "nanopc-t6.lan",
    "WAYLAND_DISPLAY": "wayland-1",
    "XDG_RUNTIME_DIR": "/run/user/1000",
    "BUNDLE_FOLDER": "/home/weston/.${appName}",
    "PING_CMD": "ping -c 1 -w 400 ${DEVICE_HOSTNAME}",
    "SCP_PREFIX": "scp -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null",
    "SSH_PREFIX": "ssh -t -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o BatchMode=yes",
    "DELETE_USER_PWD": "${SSH_PREFIX} root@${DEVICE_HOSTNAME} passwd -d weston",
    "DELETE_BUNDLE_FOLDER": "${SSH_PREFIX} weston@${DEVICE_HOSTNAME} rm -rf ${BUNDLE_FOLDER}",
    "IVI_HOMESCREEN_EXE": "${SSH_PREFIX} weston@${DEVICE_HOSTNAME} WAYLAND_DISPLAY=${WAYLAND_DISPLAY} XDG_RUNTIME_DIR=${XDG_RUNTIME_DIR} homescreen -b ${BUNDLE_FOLDER}",
    "SETUP_BUNDLE_FOLDERS_AND_SYMLINKS": "${SSH_PREFIX} weston@${DEVICE_HOSTNAME} 'mkdir -p ${BUNDLE_FOLDER}/data/flutter_assets ${BUNDLE_FOLDER}/lib && ln -sf /usr/share/flutter/${FLUTTER_VERSION}/debug/data/icudtl.dat ${BUNDLE_FOLDER}/data/icudtl.dat && ln -sf /usr/share/flutter/${FLUTTER_VERSION}/debug/lib/libflutter_engine.so ${BUNDLE_FOLDER}/lib/libflutter_engine.so'",
    "COPY_FILES_TO_DEVICE": "bash -c '${SCP_PREFIX} ${PLATFORM_ID_DIR}/config.toml weston@${DEVICE_HOSTNAME}:${BUNDLE_FOLDER}/ && ${SCP_PREFIX} -r ${localPath}/* weston@${DEVICE_HOSTNAME}:${BUNDLE_FOLDER}/data/flutter_assets'"
  },
  "runtime": {
    "config": {
      "view": [
        {
          "cursor_theme": "DMZ-White",
          "fullscreen": true
        }
      ]
    }
  },
  "overwrite-existing": true,
  "custom-device": {
    "id": "nanopc-t6-weston",
    "label": "Friendly Electric Nanopc-T6",
    "sdkNameAndVersion": "Friendly Electric Nanopc-T6 (homescreen)",
    "platform": "linux-x64",
    "enabled": true,
    "ping": "bash -c \"${PING_CMD}\"",
    "pingSuccessRegex": "1 packets transmitted, 1 received",
    "postBuild": "bash -c \"${DELETE_USER_PWD}\"",
    "install": "bash -c \"${SETUP_BUNDLE_FOLDERS_AND_SYMLINKS} && ${COPY_FILES_TO_DEVICE}\"",
    "uninstall": "bash -c \"${DELETE_BUNDLE_FOLDER}\"",
    "runDebug": "bash -c \"${IVI_HOMESCREEN_EXE}\"",
    "forwardPort": "bash -c \"${SSH_PREFIX} -o ExitOnForwardFailure=yes -L 127.0.0.1:${hostPort}:127.0.0.1:${devicePort} weston@${DEVICE_HOSTNAME} echo 'Port forwarding success'; read\"",
    "forwardPortSuccessRegex": "Port forwarding success",
    "screenshot": "bash -c \"${SSH_PREFIX} weston@${DEVICE_HOSTNAME} WAYLAND_DISPLAY=${WAYLAND_DISPLAY} XDG_RUNTIME_DIR=${XDG_RUNTIME_DIR} weston-screenshooter\""
  }
}
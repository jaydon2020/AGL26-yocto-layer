{
    "id": "pdfium",
    "load": false,
    "supported_archs": [
        "x86_64"
    ],
    "supported_host_types": [
        "ubuntu",
        "fedora"
    ],
    "type": "dependency",
    "env": {
        "PATH": "${FLUTTER_WORKSPACE}/app/depot_tools:${PATH}",
        "RUNTIME_MODE": "debug",
        "PDFIUM_ROOT": "${FLUTTER_WORKSPACE}/app/pdfium",
        "PDFIUM_SRC_DIR_RELATIVE": "pdfium",
        "PDFIUM_SRC_DIR": "${PDFIUM_ROOT}/${PDFIUM_SRC_DIR_RELATIVE}",
        "GN_ARGS": "is_debug=false pdf_is_standalone=true pdf_use_skia=true pdf_enable_v8=false is_component_build=false treat_warnings_as_errors=false is_clang=true clang_use_chrome_plugins=false use_custom_libcxx=true libcxx_is_shared=false target_os=\\\"linux\\\" target_cpu=\\\"${HOST_ARCH_GOOGLE}\\\"",
        "PDFIUM_BUILD_DIR": "${PDFIUM_SRC_DIR}/out/Linux-Release",
        "PATCH_FOLDER": "${FLUTTER_WORKSPACE}/patches/pdfium",
        "VPYTHON_VIRTUALENV_ROOT": "${PDFIUM_ROOT}/.vpython-root"
    },
    "src": [
        {
            "uri": "https://github.com/DavBfr/dart_pdf.git",
            "branch": "master"
        }
    ],
    "runtime": {
        "gclient_config": {
            "path": "${PDFIUM_ROOT}",
            "name": "${PDFIUM_SRC_DIR_RELATIVE}",
            "url": "https://pdfium.googlesource.com/pdfium.git@4e4d7a14a4d9d484feb4a4770a892cd964cfd968",
            "deps_file": "DEPS",
            "managed": false,
            "custom_deps": {},
            "custom_vars": {
                "reclient_package": "gn/gn/",
                "reclient_version": "git_revision:b99a82ca8ee957da829d6313b818b99df8e7ccb8",
                "checkout_configuration": "small"
            }
        },
        "pre-requisites": {
            "x86_64": {
                "darwin": {},
                "fedora": {
                    "cmds": [
                        "sudo dnf install -y nasm"
                    ]
                },
                "ubuntu": {
                    "cmds": [
                        "sudo apt-get install -yq nasm"
                    ]
                }
            }
        },
        "post_cmds": [
            {
                "cmds": [
                    "mkdir -p ${PDFIUM_ROOT}"
                ]
            },
            {
                "cwd": "${PDFIUM_ROOT}",
                "cmds": [
                    "mkdir -p ${VPYTHON_VIRTUALENV_ROOT}",
                    "gclient sync -D -R -j${HARDWARE_THREADS} -v"
                ]
            },
            {
                "env": {
                    "PKG_CONFIG_PATH": "/usr/lib64/pkgconfig"
                },
                "cwd": "${PDFIUM_SRC_DIR}",
                "cmds": [
                    "git reset --hard",
                    "git apply ${PATCH_FOLDER}/public_headers.patch",
                    "git apply ${PATCH_FOLDER}/shared_library.patch",
                    "git apply ${PATCH_FOLDER}/v8_init.patch",
                    "gn gen \"${PDFIUM_BUILD_DIR}\" --args=\"${GN_ARGS}\""
                ]
            },
            {
                "cwd": "${PDFIUM_SRC_DIR}",
                "cmds": [
                    "${AUTONINJA} -C ${PDFIUM_BUILD_DIR} pdfium",
                    "llvm-strip ${PDFIUM_BUILD_DIR}/libpdfium.so"
                ]
            }
        ],
        "do_clean": [
            {
                "cwd": "${PDFIUM_BUILD_DIR}",
                "cmds": [
                    "ninja -t clean"
                ]
            }
        ]
    }
}
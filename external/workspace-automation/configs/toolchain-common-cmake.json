{
    "id": "toolchain-common-cmake",
    "load": true,
    "supported_archs": [
        "aarch64",
        "x86_64",
        "ARM64",
        "AMD64"
    ],
    "supported_host_types": [
        "fedora",
        "rhel",
        "ubuntu",
        "windows"
    ],
    "type": "toolchain",
    "toolchain": "common",
    "env": {
        "VERSION": "3.31",
        "CMAKE_BUILD_PARALLEL_LEVEL": "${_MAX_THREADS}"
    },
    "append_to_runtime_env": {
        "common": [
            "# toolchain-common-cmake",
            "export PATH=$FLUTTER_WORKSPACE/.config/flutter_workspace/toolchain-common-cmake/bin:$PATH",
            "export CMAKE_BUILD_PARALLEL_LEVEL=${_MAX_THREADS}"
        ],
        "windows": [
            "# toolchain-common-cmake",
            "$env:PATH = \"$env:FLUTTER_WORKSPACE\\.config\\flutter_workspace\\toolchain-common-cmake\\bin;$env:PATH\"",
            "$env:CMAKE_BUILD_PARALLEL_LEVEL = \"$env:_MAX_THREADS\""
        ]
    },
    "runtime": {
        "artifacts": {
            "http": {
                "url": "https://cmake.org/files",
                "artifacts": {
                    "x86_64": [
                        {
                            "filename": "cmake-${VERSION}.7-linux-${HOST_ARCH}.tar.gz",
                            "endpoint": "/v${VERSION}/cmake-${VERSION}.7-linux-${HOST_ARCH}.tar.gz",
                            "sha256": "14e15d0b445dbeac686acc13fe13b3135e8307f69ccf4c5c91403996ce5aa2d4",
                            "post_cmds": [
                                {
                                    "cwd": "${PLATFORM_ID_DIR}",
                                    "cmds": [
                                        "tar --strip-components=1 -xzf ${PLATFORM_ID_DIR}/artifacts/cmake-${VERSION}.7-linux-${HOST_ARCH}.tar.gz -C ."
                                    ]
                                }
                            ]
                        }
                    ],
                    "aarch64": [
                        {
                            "filename": "cmake-${VERSION}.7-linux-${HOST_ARCH}.tar.gz",
                            "endpoint": "/v${VERSION}/cmake-${VERSION}.7-linux-${HOST_ARCH}.tar.gz",
                            "sha256": "e5b2dc2aefdca10afe09c8fa4ee2bbb4e732665943a94322f99c118781910c3c",
                            "post_cmds": [
                                {
                                    "cwd": "${PLATFORM_ID_DIR}",
                                    "cmds": [
                                        "tar --strip-components=1 -xzf ${PLATFORM_ID_DIR}/artifacts/cmake-${VERSION}.7-linux-${HOST_ARCH}.tar.gz -C ."
                                    ]
                                }
                            ]
                        }
                    ],
                    "AMD64": [
                        {
                            "filename": "cmake-${VERSION}.7-windows-x86_64.zip",
                            "endpoint": "/v${VERSION}/cmake-${VERSION}.7-windows-x86_64.zip",
                            "sha256": "ab1c7f46a1b1314f9fcb766c2573148679af599d94c5566bc12b8b35bb563362",
                            "post_cmds": [
                                {
                                    "cwd": "${PLATFORM_ID_DIR}",
                                    "cmds": [
                                        "ls ${PLATFORM_ID_DIR}/artifacts",
                                        "python3 -m zipfile -e \"${PLATFORM_ID_DIR}/artifacts/cmake-${VERSION}.7-windows-x86_64.zip\" ."
                                    ]
                                }
                            ]
                        }
                    ],
                    "ARM64": [
                        {
                            "filename": "cmake-${VERSION}.7-windows-arm64.zip",
                            "endpoint": "/v${VERSION}/cmake-${VERSION}.7-windows-arm64.zip",
                            "sha256": "5b72d0dcd66dadbbb90789c70789db92302342cc7b91df62059a26e230544f05",
                            "post_cmds": [
                                {
                                    "cwd": "${PLATFORM_ID_DIR}",
                                    "cmds": [
                                        "python3 -m zipfile -e \"${PLATFORM_ID_DIR}/artifacts/cmake-${VERSION}.7-windows-arm64.zip\" ."
                                    ]
                                }
                            ]
                        }
                    ]
                }
            }
        }
    }
}
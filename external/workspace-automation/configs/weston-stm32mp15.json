{
  "id": "weston-stm32mp15",
  "load": false,
  "supported_archs": [
    "aarch64",
    "arm64",
    "x86_64"
  ],
  "supported_host_types": [
    "darwin",
    "fedora",
    "ubuntu"
  ],
  "type": "remote",
  "env": {
    "DEVICE_HOSTNAME": "stm32mp15-disco.local",
    "COMPOSITOR_USER": "weston",
    "PING_CMD": "ping -c 1 -w 400 ${DEVICE_HOSTNAME}",
    "SCP_PREFIX": "scp -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null",
    "SSH_PREFIX": "ssh -t -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o BatchMode=yes",
    "DELETE_USER_PWD": "${SSH_PREFIX} root@${DEVICE_HOSTNAME} passwd -d ${COMPOSITOR_USER}",
    "IVI_HOMESCREEN_EXE": "homescreen -b /tmp/${appName}",
    "DELETE_APP_FOLDER": "${SSH_PREFIX} ${COMPOSITOR_USER}@${DEVICE_HOSTNAME} rm -rf /tmp/${appName}",
    "CREATE_BUNDLE_FOLDER": "${SSH_PREFIX} ${COMPOSITOR_USER}@${DEVICE_HOSTNAME} mkdir -p /tmp/${appName}/data",
    "COPY_ASSETS_TO_DEVICE": "${SCP_PREFIX} -r ${localPath}/* ${COMPOSITOR_USER}@${DEVICE_HOSTNAME}:/tmp/${appName}/data/flutter_assets",
    "COPY_PLATFORM_ID_CONFIG_TO_DEVICE": "${SCP_PREFIX} ${PLATFORM_ID_DIR}/config.toml ${COMPOSITOR_USER}@${DEVICE_HOSTNAME}:/tmp/${appName}/"
  },
  "runtime": {
    "config": {
      "view": [
        {
          "cursor_theme": "DMZ-White",
          "fullscreen": true
        }
      ]
    }
  },
  "overwrite-existing": true,
  "custom-device": {
    "id": "stm32mp15-weston",
    "label": "STM32MP157F-DK2",
    "sdkNameAndVersion": "STM32 Discovery Board (Dual Cortex-A7)",
    "platform": "linux-x64",
    "enabled": true,
    "ping": "bash -c \"${PING_CMD}\"",
    "pingSuccessRegex": "[<=]\\d+ms",
    "postBuild": "bash -c \"${DELETE_USER_PWD}\"",
    "install": "bash -c \"${CREATE_BUNDLE_FOLDER} && ${COPY_PLATFORM_ID_CONFIG_TO_DEVICE} && ${COPY_ASSETS_TO_DEVICE}\"",
    "uninstall": "bash -c \"${DELETE_APP_FOLDER}\"",
    "runDebug": "bash -c \"${SSH_PREFIX} ${COMPOSITOR_USER}@${DEVICE_HOSTNAME} ${IVI_HOMESCREEN_EXE}\"",
    "forwardPort": "bash -c \"${SSH_PREFIX} -o ExitOnForwardFailure=yes -L 127.0.0.1:${hostPort}:127.0.0.1:${devicePort} ${COMPOSITOR_USER}@${DEVICE_HOSTNAME} echo 'Port forwarding success'; read\"",
    "forwardPortSuccessRegex": "Port forwarding success",
    "screenshot": null
  }
}
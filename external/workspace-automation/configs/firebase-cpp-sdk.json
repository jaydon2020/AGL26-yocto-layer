{
    "id": "firebase-cpp-sdk",
    "load": false,
    "supported_archs": [
        "aarch64",
        "arm64",
        "x86_64"
    ],
    "supported_host_types": [
        "ubuntu",
        "fedora"
    ],
    "type": "dependency",
    "env": {
        "PATH": "${FLUTTER_WORKSPACE}/.config/flutter_workspace/toolchain-common-ninja:${FLUTTER_WORKSPACE}/.config/flutter_workspace/toolchain-common-cmake/bin:$PATH",
        "LD_LIBRARY_PATH": "${FLUTTER_WORKSPACE}/.config/flutter_workspace/toolchain-common-cmake/lib",
        "FIREBASE_SRC_DIR": "${FLUTTER_WORKSPACE}/app/firebase-cpp-sdk",
        "FIREBASE_BUILD_DIR": "${FLUTTER_WORKSPACE}/app/firebase-cpp-sdk/build",
        "FIREBASE_STAGING_DIR": "${FIREBASE_BUILD_DIR}/staging/release",
        "FIREBASE_CMAKE_ARGS": "-DFIREBASE_USE_BORINGSSL=ON -DFIREBASE_LINUX_USE_CXX11_ABI=ON -DCMAKE_STAGING_PREFIX=${FIREBASE_STAGING_DIR} -DCMAKE_BUILD_TYPE=${CMAKE_BUILD_TYPE}"
    },
    "src": [
        {
            "uri": "https://github.com/firebase/firebase-cpp-sdk.git",
            "branch": "main",
            "rev": "v12.5.0"
        },
        {
            "uri": "https://github.com/firebase/flutterfire.git",
            "branch": "main"
        },
        {
            "uri": "https://github.com/firebase/FirebaseUI-Flutter",
            "branch": "main"
        }
    ],
    "runtime": {
        "pre-requisites": {
            "aarch64": {
                "ubuntu": {
                    "cmds": [
                        "pip3 install absl-py",
                        "sudo rm -rf /usr/local/go | true",
                        "wget https://golang.org/dl/go1.21.5.linux-amd64.tar.gz",
                        "sudo tar -C /usr/local -xzf go1.21.5.linux-amd64.tar.gz",
                        "rm go1.21.5.linux-amd64.tar.gz"
                    ]
                }
            },
            "x86_64": {
                "ubuntu": {
                    "cmds": [
                        "pip3 install absl-py",
                        "sudo rm -rf /usr/local/go | true",
                        "wget https://golang.org/dl/go1.21.5.linux-amd64.tar.gz",
                        "sudo tar -C /usr/local -xzf go1.21.5.linux-amd64.tar.gz",
                        "rm go1.21.5.linux-amd64.tar.gz"
                    ]
                },
                "fedora": {
                    "cmds": [
                        "pip3 install absl-py",
                        "sudo dnf install go"
                    ]
                }
            }
        },
        "post_cmds": [
            {
                "cwd": "${FIREBASE_SRC_DIR}",
                "cmds": [
                    "git reset --hard",
                    "git apply ${FLUTTER_WORKSPACE}/patches/firebase-cpp-sdk/0001-Disable-unknown-compiler-options.patch"
                ]
            },
            {
                "env": {
                    "PATH": "${PATH}:/usr/local/go/bin"
                },
                "cwd": "${FIREBASE_BUILD_DIR}",
                "cmds": [
                    "go version",
                    "bash -c \"rm -rf CMakeCache.txt CMakeFiles | true\"",
                    "cmake -GNinja ${FIREBASE_CMAKE_ARGS} -S ${FIREBASE_SRC_DIR} -B .",
                    "${AUTONINJA}"
                ]
            }
        ],
        "do_clean": [
            {
                "cwd": "${FIREBASE_BUILD_DIR}",
                "cmds": [
                    "ninja -t clean"
                ]
            }
        ]
    }
}